

@model SoftHub.Models.Software

@if (Model != null)
{
    <h2>@Model.Name</h2>

    <img src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/no-image.png" : Model.ImagePath)" width="300" />

    <p>
        @(string.IsNullOrEmpty(Model.Description) 
            ? "لا يوجد وصف" 
            : Model.Description)
    </p>

    @if (!string.IsNullOrEmpty(Model.FilePath))
    {
        <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-success">
            تحميل
        </a>
    }
    else 
    {
        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-warning">
            سجل دخول للتحميل 🔒
        </a>
    }
    @* else
    {
        <p>لا يوجد ملف</p>
    } *@
}
else
{
    <p>البرنامج غير موجود</p>
}





















