@model SoftHub.Models.Software

<h2>إضافة برنامج</h2>

<form asp-action="Create" enctype="multipart/form-data">

    <div>
        <label>الاسم</label>
        <input asp-for="Name" />
    </div>

    <div>
        <label>الوصف</label>
        <input asp-for="Description" />
    </div>

    <div>
        <label>الصورة</label>
        <input type="file" asp-for="ImageFile" />
    </div>

    <div>
        <label>الملف (برنامج أو فيديو)</label>
        <input type="file" asp-for="UploadFile" />
    </div>

    <button type="submit">حفظ</button>
    <div style="background:#1f1f1f;padding:20px;border-radius:15px;max-width:500px;"> </div>
</form>