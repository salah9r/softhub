<h2 style="color:#c77dff;">📊 Dashboard</h2>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;">

    <div class="card">👨‍💻 @ViewBag.Users</div>
    <div class="card">📦 @ViewBag.Softwares</div>
    <div class="card">⬇️ @ViewBag.Downloads</div>
    <div class="card">👀 @ViewBag.Visits</div>

</div>

<canvas id="visitsChart" style="margin-top:40px;"></canvas>

<script>
    var canvas = document.getElementById('visitsChart');

    if (canvas) {

        var dates = @Html.Raw(Json.Serialize(ViewBag.Dates ?? new List<string>()));
        var counts = @Html.Raw(Json.Serialize(ViewBag.Counts ?? new List<int>()));

        var ctx = canvas.getContext('2d');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: dates,
                datasets: [{
                    label: 'الزيارات',
                    data: counts,
                    borderWidth: 2,
                    tension: 0.4
                }]
            }
        });
    }
</script>

<style>
    .card {
        background: linear-gradient(145deg,#240046,#3c096c);
        padding: 20px;
        border-radius: 15px;
        text-align: center;
        color: white;
        font-size: 20px;
    }
</style>


















